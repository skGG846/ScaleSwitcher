<Window x:Class="ScaleSwitcher.Views.OsdWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="OsdWindow"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" Focusable="False" Cursor="None">
    <Grid>
        <Border Background="#CC000000" CornerRadius="20" Padding="40" HorizontalAlignment="Center" VerticalAlignment="Center">
            <TextBlock x:Name="MessageText" Foreground="White" FontSize="48" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center" />
        </Border>
    </Grid>
</Window>
